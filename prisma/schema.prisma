generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                      @id @default(autoincrement())
  name                  String
  email                 String                   @unique
  password              String
  createdAt             DateTime                 @default(now())
  role                  Role                     @default(USER)
  isActive              Boolean                  @default(true)
  lastLoginAt           DateTime?
  lastLoginIp           String?
  passwordChangedAt     DateTime?
  search_vector         Unsupported("tsvector")?
  lockout               AccountLockout?
  ApiKey                ApiKey[]
  applications          Application[]
  AuditLog              AuditLog[]
  baseProfile           BaseProfile?
  charityAccount        CharityAccount?
  refreshTokens         RefreshToken[]
  reviewedRegistrations RegistrationRequest[]    @relation("ReviewedByUser")
  reviewedVerifications VerificationRequest[]    @relation("ReviewedByUser")
  verificationRequests  VerificationRequest[]
  notifications         Notification[]
  volunteerProfile      VolunteerProfile?

  @@index([search_vector], map: "user_search_vector_idx", type: Gin)
}

model BaseProfile {
  id        Int      @id @default(autoincrement())
  phone     String?
  avatarUrl String?
  city      String?
  country   String?
  bio       String?
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VolunteerProfile {
  id               Int                   @id @default(autoincrement())
  userId           Int                   @unique
  isAvailable      Boolean               @default(true)
  availabilityNote String?
  experience       String?
  isVerified       Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  preferences      VolunteerPreference[]
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills           VolunteerSkill[]
}

model VolunteerSkill {
  id          Int              @id @default(autoincrement())
  volunteerId Int
  skill       String
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([skill])
}

model VolunteerPreference {
  id          Int              @id @default(autoincrement())
  volunteerId Int
  type        PreferenceType
  value       String
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([type, value])
}

model CharityAccount {
  id              Int                      @id @default(autoincrement())
  name            String
  description     String?
  logoUrl         String?
  websiteUrl      String?
  phone           String?
  address         String?
  city            String?
  isVerified      Boolean                  @default(false)
  userId          Int                      @unique
  createdAt       DateTime                 @default(now())
  category        Category?
  search_vector   Unsupported("tsvector")?
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  charityProjects CharityProject[]

  @@index([search_vector], map: "idx_charity_search", type: Gin)
}

model CharityProject {
  id           Int            @id @default(autoincrement())
  title        String
  description  String
  status       ProjectStatus  @default(ACTIVE)
  createdAt    DateTime       @default(now())
  charityId    Int
  category     Category?
  applications Application[]
  charity      CharityAccount @relation(fields: [charityId], references: [id], onDelete: Cascade)

  @@index([charityId])
  @@index([status])
}

model Application {
  id               Int            @id @default(autoincrement())
  message          String?
  createdAt        DateTime       @default(now())
  userId           Int
  charityProjectId Int
  charityProject   CharityProject @relation(fields: [charityProjectId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, charityProjectId])
  @@index([charityProjectId])
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  deviceInfo String?
  family     String?
  ipAddress  String?
  isRevoked  Boolean  @default(false)
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([family])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String
  ipAddress String
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
}

model AccountLockout {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  lockoutUntil DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RegistrationRequest {
  id         Int           @id @default(autoincrement())
  status     RequestStatus @default(PENDING)
  name       String
  email      String
  phone      String?
  city       String?
  category   Category?
  message    String?
  reviewNote String?
  reviewedAt DateTime?
  reviewedBy Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  reviewer   User?         @relation("ReviewedByUser", fields: [reviewedBy], references: [id])
}

model VerificationRequest {
  id         Int           @id @default(autoincrement())
  status     RequestStatus @default(PENDING)
  userId     Int
  documents  String[]
  message    String?
  reviewNote String?
  reviewedAt DateTime?
  reviewedBy Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  reviewer   User?         @relation("ReviewedByUser", fields: [reviewedBy], references: [id])
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String    @default("")
  icon        String    @default("")
  status      String    @default("disconnected")
  config      Json      @default("{}")
  connectedAt DateTime?
  updatedAt   DateTime  @default(now())
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String
  keyHash     String    @unique
  prefix      String
  permissions String[]  @default([])
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdById Int
  createdAt   DateTime  @default(now())
  isRevoked   Boolean   @default(false)
  User        User      @relation(fields: [createdById], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdById])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  target     String
  targetType String
  details    String   @default("")
  ipAddress  String?
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt])
}

model DynamicRole {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @unique
  description           String                  @default("")
  isSystem              Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now())
  DynamicRolePermission DynamicRolePermission[]
}

model DynamicRolePermission {
  id          Int         @id @default(autoincrement())
  roleId      Int
  permission  String
  DynamicRole DynamicRole @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([roleId, permission])
}

model EmailTemplate {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String   @default("")
  subject     String
  body        String
  variables   String[] @default([])
  updatedAt   DateTime @default(now())
}

model PlatformSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info")  // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?  // optional: click to navigate somewhere
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum PreferenceType {
  CITY
  CATEGORY
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

enum Role {
  USER
  ADMIN
  CHARITY
  VOLUNTEER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum Category {
  EDUCATION
  HEALTH
  ENVIRONMENT
  ANIMAL_WELFARE
  SOCIAL
  OTHER
}