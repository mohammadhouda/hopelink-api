generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                      @id @default(autoincrement())
  name                  String
  email                 String                   @unique
  password              String
  createdAt             DateTime                 @default(now())
  role                  Role                     @default(USER)
  isActive              Boolean                  @default(true)
  lastLoginAt           DateTime?
  lastLoginIp           String?
  passwordChangedAt     DateTime?
  search_vector         Unsupported("tsvector")?
  lockout                 AccountLockout?
  ApiKey                  ApiKey[]
  AuditLog                AuditLog[]
  baseProfile             BaseProfile?
  charityAccount          CharityAccount?
  refreshTokens           RefreshToken[]
  reviewedRegistrations   RegistrationRequest[]    @relation("ReviewedByUser")
  reviewedVerifications   VerificationRequest[]    @relation("ReviewedByUser")
  verificationRequests    VerificationRequest[]
  notifications           Notification[]
  volunteerProfile        VolunteerProfile?
  opportunityApplications OpportunityApplication[]
  ratingsReceived         VolunteerRating[]
  certificates            Certificate[]
  sentMessages            RoomMessage[]
  roomMemberships         RoomMember[]
  posts                   Post[]
  postLikes               PostLike[]
  postComments            PostComment[]
  matchScores             VolunteerMatchScore[]

  @@index([search_vector], map: "user_search_vector_idx", type: Gin)
}

model BaseProfile {
  id        Int      @id @default(autoincrement())
  phone     String?
  avatarUrl String?
  city      City?
  country   String?
  bio       String?
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VolunteerProfile {
  id               Int                    @id @default(autoincrement())
  userId           Int                    @unique
  isAvailable      Boolean                @default(true)
  availabilityDays String[]               @default([])
  experience       String?
  isVerified       Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  preferences      VolunteerPreference[]
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills           VolunteerSkill[]
  experiences      VolunteerExperience[]
}

model VolunteerExperience {
  id          Int              @id @default(autoincrement())
  volunteerId Int
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean          @default(false)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([volunteerId])
}

model VolunteerSkill {
  id          Int              @id @default(autoincrement())
  volunteerId Int
  skill       String
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([skill])
}

model VolunteerPreference {
  id          Int              @id @default(autoincrement())
  volunteerId Int
  type        PreferenceType
  value       String
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([type, value])
}

model VolunteerMatchScore {
  volunteerId   Int
  opportunityId Int
  score         Float
  computedAt    DateTime                @default(now())
  volunteer     User                    @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  opportunity   VolunteeringOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@id([volunteerId, opportunityId])
  @@index([volunteerId, score(sort: Desc)])
}

model CharityAccount {
  id              Int                      @id @default(autoincrement())
  name            String
  description     String?
  logoUrl         String?
  websiteUrl      String?
  phone           String?
  address         String?
  city            City?
  isVerified      Boolean                  @default(false)
  userId          Int                      @unique
  createdAt       DateTime                 @default(now())
  category        Category?
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  charityProjects CharityProject[]
  opportunities   VolunteeringOpportunity[]
  ratingsGiven    VolunteerRating[]
  issuedCerts     Certificate[]
}

model CharityProject {
  id            Int                       @id @default(autoincrement())
  title         String
  description   String
  status        ProjectStatus             @default(ACTIVE)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  charityId     Int
  category      Category?
  opportunities VolunteeringOpportunity[]
  charity       CharityAccount            @relation(fields: [charityId], references: [id], onDelete: Cascade)

  @@index([charityId])
  @@index([status])
}


model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  deviceInfo String?
  family     String?
  ipAddress  String?
  isRevoked  Boolean  @default(false)
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([family])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String
  ipAddress String
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
}

model AccountLockout {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  lockoutUntil DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RegistrationRequest {
  id         Int           @id @default(autoincrement())
  status     RequestStatus @default(PENDING)
  name       String
  email      String
  phone      String?
  city       String?
  category   Category?
  message    String?
  reviewNote String?
  reviewedAt DateTime?
  reviewedBy Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  reviewer   User?         @relation("ReviewedByUser", fields: [reviewedBy], references: [id])
}

model VerificationRequest {
  id         Int           @id @default(autoincrement())
  status     RequestStatus @default(PENDING)
  userId     Int
  documents  String[]
  message    String?
  reviewNote String?
  reviewedAt DateTime?
  reviewedBy Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  reviewer   User?         @relation("ReviewedByUser", fields: [reviewedBy], references: [id])
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String    @default("")
  icon        String    @default("")
  status      String    @default("disconnected")
  config      Json      @default("{}")
  connectedAt DateTime?
  updatedAt   DateTime  @default(now())
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String
  keyHash     String    @unique
  prefix      String
  permissions String[]  @default([])
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdById Int
  createdAt   DateTime  @default(now())
  isRevoked   Boolean   @default(false)
  User        User      @relation(fields: [createdById], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdById])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  target     String
  targetType String
  details    String   @default("")
  ipAddress  String?
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt])
}

model DynamicRole {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @unique
  description           String                  @default("")
  isSystem              Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now())
  DynamicRolePermission DynamicRolePermission[]
}

model DynamicRolePermission {
  id          Int         @id @default(autoincrement())
  roleId      Int
  permission  String
  DynamicRole DynamicRole @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([roleId, permission])
}

model EmailTemplate {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String   @default("")
  subject     String
  body        String
  variables   String[] @default([])
  updatedAt   DateTime @default(now())
}

model PlatformSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @default(now())
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum PreferenceType {
  CITY
  CATEGORY
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

enum Role {
  USER
  ADMIN
  CHARITY
  VOLUNTEER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum Category {
  EDUCATION
  HEALTH
  ENVIRONMENT
  ANIMAL_WELFARE
  SOCIAL
  OTHER
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DECLINED
}

enum OpportunityStatus {
  OPEN
  FULL
  ENDED
  CANCELLED
}

enum RoomStatus {
  ACTIVE
  CLOSED
}

enum RoomRole {
  ADMIN
  MEMBER
}

model VolunteeringOpportunity {
  id           Int                      @id @default(autoincrement())
  title        String
  description  String
  startDate    DateTime
  endDate      DateTime
  location     City?
  maxSlots     Int                      @default(10)
  status       OpportunityStatus        @default(OPEN)
  requiredSkills String[]               @default([])
  availabilityDays String[]             @default([])
  charityId    Int
  projectId    Int?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  charity      CharityAccount           @relation(fields: [charityId], references: [id], onDelete: Cascade)
  project      CharityProject?          @relation(fields: [projectId], references: [id])
  applications OpportunityApplication[]
  room         VolunteerRoom?
  certificates Certificate[]
  ratings      VolunteerRating[]
  matchScores  VolunteerMatchScore[]

  @@index([charityId])
  @@index([status])
  @@index([startDate])
}

model OpportunityApplication {
  id            Int                     @id @default(autoincrement())
  message       String?
  status        ApplicationStatus       @default(PENDING)
  userId        Int
  opportunityId Int
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity   VolunteeringOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([opportunityId])
  @@index([status])
}

model VolunteerRating {
  id            Int                     @id @default(autoincrement())
  rating        Int
  comment       String?
  charityId     Int
  volunteerId   Int
  opportunityId Int
  createdAt     DateTime                @default(now())
  charity       CharityAccount          @relation(fields: [charityId], references: [id], onDelete: Cascade)
  volunteer     User                    @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  opportunity   VolunteeringOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([charityId, volunteerId, opportunityId])
  @@index([volunteerId])
  @@index([opportunityId])
}

model Certificate {
  id              Int                     @id @default(autoincrement())
  volunteerId     Int
  opportunityId   Int
  charityId       Int
  issuedAt        DateTime                @default(now())
  certificateData Json?
  pdfUrl          String?
  volunteer       User                    @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  opportunity     VolunteeringOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  charity         CharityAccount          @relation(fields: [charityId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, opportunityId])
  @@index([volunteerId])
  @@index([opportunityId])
}

model VolunteerRoom {
  id            Int                     @id @default(autoincrement())
  opportunityId Int                     @unique
  status        RoomStatus              @default(ACTIVE)
  createdAt     DateTime                @default(now())
  closedAt      DateTime?
  opportunity   VolunteeringOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  messages      RoomMessage[]
  members       RoomMember[]
}

model RoomMessage {
  id        Int           @id @default(autoincrement())
  roomId    Int
  senderId  Int
  content   String
  createdAt DateTime      @default(now())
  room      VolunteerRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

model RoomMember {
  id       Int           @id @default(autoincrement())
  roomId   Int
  userId   Int
  role     RoomRole      @default(MEMBER)
  joinedAt DateTime      @default(now())
  room     VolunteerRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

model Post {
  id        Int           @id @default(autoincrement())
  content   String
  imageUrl  String?
  authorId  Int
  postType  PostType      @default(GENERAL)
  refId     Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]
  comments  PostComment[]

  @@index([authorId])
  @@index([createdAt])
}

model PostLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model PostComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

enum PostType {
  GENERAL
  CERTIFICATE
  PROJECT
}

enum City {
  BEIRUT
  TRIPOLI
  SIDON
  TYRE
  JOUNIEH
  BYBLOS
  ZAHLE
  BAALBEK
  NABATIEH
  ALEY
  CHOUF
  METN
  KESREWAN
  AKKAR
  OTHER
}