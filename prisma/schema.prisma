generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// Users and Roles
// =======================
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Security
  lastLoginAt       DateTime?
  lastLoginIp       String?
  passwordChangedAt DateTime?

  // Role-based profiles
  profile          UserProfile?
  volunteerProfile VolunteerProfile?
  charityAccount   CharityAccount?

  // Relations
  applications  Application[]
  refreshTokens RefreshToken[]
  lockout       AccountLockout?
}

// =======================
// User Profiles
// =======================
model UserProfile {
  id        Int      @id @default(autoincrement())
  phone     String?
  avatarUrl String?
  city      String?
  country   String?
  bio       String?

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VolunteerProfile {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  isAvailable      Boolean @default(true)
  availabilityNote String?
  experience       String?
  isVerified       Boolean @default(false)

  skills      VolunteerSkill[]
  preferences VolunteerPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VolunteerSkill {
  id          Int @id @default(autoincrement())
  volunteerId Int
  skill       String

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([skill])
}

model VolunteerPreference {
  id          Int @id @default(autoincrement())
  volunteerId Int
  type        PreferenceType
  value       String

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([type, value])
}


// =======================
// Charity Accounts & Projects
// =======================
model CharityAccount {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  phone       String?
  address     String?
  city        String?
  category    String?

  isVerified Boolean @default(false)

  userId Int @unique
  createdAt DateTime @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  charityProjects CharityProject[]
}


model CharityProject {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  category    String?
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  charityId Int
  charity   CharityAccount @relation(fields: [charityId], references: [id], onDelete: Cascade)

  applications Application[]

  @@index([charityId])
  @@index([status])
}

// =======================
// Applications
// =======================
model Application {
  id        Int      @id @default(autoincrement())
  message   String?
  createdAt DateTime @default(now())

  userId        Int
  charityProjectId Int

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  charityProject CharityProject @relation(fields: [charityProjectId], references: [id], onDelete: Cascade)

  @@unique([userId, charityProjectId])
  @@index([charityProjectId])
}

// =======================
// Authentication & Security
// =======================
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  ipAddress  String?
  userAgent  String?
  deviceInfo String?
  family     String?
  isRevoked  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([family])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String
  ipAddress String
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
}

model AccountLockout {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  lockoutUntil DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =======================
// Enums
// =======================
enum Role {
  USER
  ADMIN
  CHARITY
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum PreferenceType {
  CITY
  CATEGORY
}